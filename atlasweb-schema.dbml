Table __EFMigrationsHistory {
  MigrationId varchar(150) [pk]
  ProductVersion varchar(32) [not null]
}

Ref: Kullanicilar.MusteriId > Musteriler.Id
Ref: Birimler.MusteriId > Musteriler.Id
Ref: CariTipler.MusteriId > Musteriler.Id
Ref: CariKartlar.MusteriId > Musteriler.Id
Ref: CariKartlar.CariTipId > CariTipler.Id
Ref: CariKartlar.HksSifatId > HksSifatlar.HksSifatId
Ref: Stoklar.MusteriId > Musteriler.Id
Ref: Stoklar.BirimId > Birimler.Id
Ref: Faturalar.MusteriId > Musteriler.Id
Ref: Faturalar.CariKartId > CariKartlar.Id
Ref: FaturaDetaylari.MusteriId > Musteriler.Id
Ref: FaturaDetaylari.FaturaId > Faturalar.Id
Ref: FaturaDetaylari.StokId > Stoklar.Id
Ref: KasaFisleri.MusteriId > Musteriler.Id
Ref: KasaFisleri.CariKartId > CariKartlar.Id
Ref: HksAyarlari.MusteriId > Musteriler.Id
Ref: HksReferansKunyeKayitlari.MusteriId > Musteriler.Id
Ref: KullaniciTokenler.KullaniciId > Kullanicilar.Id
Ref: KullaniciSifreSifirlamaTokenler.KullaniciId > Kullanicilar.Id

// HKS sözlük tabloları için mantıksal ilişkiler
Ref: HksIlceler.HksIlId > HksIller.HksIlId
Ref: HksBeldeler.HksIlceId > HksIlceler.HksIlceId
Ref: HksUrunCinsleri.HksUrunId > HksUrunler.HksUrunId
Ref: HksUrunCinsleri.HksUretimSekliId > HksUretimSekilleri.HksUretimSekliId
Ref: Stoklar.HksUrunId > HksUrunler.HksUrunId
Ref: Stoklar.HksUretimSekliId > HksUretimSekilleri.HksUretimSekliId
Ref: Stoklar.HksUrunCinsiId > HksUrunCinsleri.HksUrunCinsiId
