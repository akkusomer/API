Enum AuditSource {
  Web
  System
  Security
}

Enum KimlikTuruEnum {
  VKN
  TCKN
}

Enum PaketTipiEnum {
  Standart
  Premium
  Kurumsal
}

Enum FaturaTipiEnum {
  Bireysel
  Kurumsal
  Ihracat
}

Enum KasaIslemTipi {
  Tahsilat
  Odeme
}

Table Musteriler {
  Id uuid [pk]
  MusteriKodu text [not null]
  Unvan text [not null]
  VergiNo text [not null]
  VergiDairesi text [not null]
  KimlikTuru KimlikTuruEnum [not null]
  GsmNo text [not null]
  EPosta text [not null]
  Il text [not null]
  Ilce text [not null]
  AdresDetay text [not null]
  PaketTipi PaketTipiEnum [not null]
  AktifMi boolean [not null]
  KayitTarihi timestamp [not null]

  Indexes {
    MusteriKodu [unique, name: 'IX_Musteriler_MusteriKodu_Unique']
  }
}

Table Kullanicilar {
  Id uuid [pk]
  MusteriId uuid [not null]
  Ad text [not null]
  Soyad text [not null]
  EPosta text [not null]
  Telefon text
  SifreHash text [not null]
  Rol text [not null]
  FailedLoginCount int [not null]
  LockoutEnd timestamp
  AktifMi boolean [not null]
  KayitTarihi timestamp [not null]
  OlusturanKullanici text
  GuncellemeTarihi timestamp
  GuncelleyenKullanici text
  SilinmeTarihi timestamp
  SilenKullanici text
  Source AuditSource [not null]

  Indexes {
    EPosta [unique, name: 'IX_Kullanicilar_EPosta_Unique']
  }
}

Table KullaniciTokenler {
  Id uuid [pk]
  KullaniciId uuid [not null]
  RefreshTokenHash text [not null]
  ExpiryTime timestamp [not null]
  DeviceInfo text
  CreatedAt timestamp [not null]

  Indexes {
    RefreshTokenHash [unique, name: 'IX_KullaniciTokenler_RefreshTokenHash_Unique']
    (KullaniciId, ExpiryTime) [name: 'IX_KullaniciTokenler_KullaniciId_Expiry']
  }
}

Table KullaniciSifreSifirlamaTokenler {
  Id uuid [pk]
  KullaniciId uuid [not null]
  TokenHash text [not null]
  ExpiryTime timestamp [not null]
  CreatedAt timestamp [not null]
  ConsumedAt timestamp
  RequestedIpAddress text

  Indexes {
    TokenHash [unique, name: 'IX_KullaniciSifreSifirlamaTokenler_TokenHash_Unique']
    (KullaniciId, ExpiryTime) [name: 'IX_KullaniciSifreSifirlamaTokenler_KullaniciId_Expiry']
  }
}

Table Birimler {
  Id uuid [pk]
  MusteriId uuid [not null]
  Ad text [not null]
  Sembol text [not null]
  AktifMi boolean [not null]
  KayitTarihi timestamp [not null]
  OlusturanKullanici text
  GuncellemeTarihi timestamp
  GuncelleyenKullanici text
  SilinmeTarihi timestamp
  SilenKullanici text
  Source AuditSource [not null]

  Indexes {
    (MusteriId, Ad) [unique, name: 'IX_Birimler_MusteriId_Ad_Unique']
    (MusteriId, Sembol) [unique, name: 'IX_Birimler_MusteriId_Sembol_Unique']
  }
}

Table CariTipler {
  Id uuid [pk]
  MusteriId uuid [not null]
  Adi varchar(50) [not null]
  Aciklama varchar(200)
  AktifMi boolean [not null]
  KayitTarihi timestamp [not null]
  OlusturanKullanici text
  GuncellemeTarihi timestamp
  GuncelleyenKullanici text
  SilinmeTarihi timestamp
  SilenKullanici text
  Source AuditSource [not null]

  Indexes {
    (MusteriId, Adi) [unique, name: 'IX_CariTipler_MusteriId_Adi_Unique']
  }
}

Table CariKartlar {
  Id uuid [pk]
  MusteriId uuid [not null]
  CariTipId uuid [not null]
  Unvan varchar(150)
  AdiSoyadi varchar(100)
  FaturaTipi FaturaTipiEnum [not null]
  GrupKodu varchar(20)
  OzelKodu varchar(20)
  Telefon varchar(20)
  Telefon2 varchar(20)
  Gsm varchar(20)
  Adres varchar(250)
  HksSifatId int
  Il varchar(100)
  Ilce varchar(100)
  Belde varchar(100)
  VergiDairesi varchar(50)
  VTCK_No varchar(11)
  AktifMi boolean [not null]
  KayitTarihi timestamp [not null]
  OlusturanKullanici text
  GuncellemeTarihi timestamp
  GuncelleyenKullanici text
  SilinmeTarihi timestamp
  SilenKullanici text
  Source AuditSource [not null]

  Indexes {
    (MusteriId, VTCK_No) [unique, name: 'IX_CariKartlar_MusteriId_VTCK_No_Unique']
  }
}

Table Stoklar {
  Id uuid [pk]
  MusteriId uuid [not null]
