ATLASWEB_DB_PASSWORD=replace-with-a-strong-database-password
ATLASWEB_JWT_KEY=replace-with-a-random-jwt-secret-at-least-32-bytes-long
ATLASWEB_SEED_ADMIN_PASSWORD=replace-with-a-strong-initial-admin-password
ATLASWEB_ALLOWED_ORIGIN=http://localhost:3000
ATLASWEB_ENABLE_SWAGGER=false
ATLASWEB_ALLOW_INSECURE_REFRESH_COOKIE=false
